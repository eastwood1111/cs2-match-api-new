.bind-page {
  padding-bottom: 48rpx;
}

.form-panel {
  box-sizing: border-box;
  padding: 8rpx 28rpx;
  border: 1rpx solid #e0e3e8;
  border-radius: 8rpx;
  background: #ffffff;
}

.field {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #eef0f3;
}

.field:last-child {
  border-bottom: 0;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  color: #505761;
  font-size: 24rpx;
  font-weight: 800;
}

.input {
  width: 100%;
  height: 72rpx;
  color: #17191c;
  font-size: 30rpx;
}

.url-input {
  font-size: 24rpx;
}

.field-hint {
  display: block;
  margin-top: 8rpx;
  color: #747b86;
  font-size: 22rpx;
}

.notice {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-left: 8rpx solid #d84a3a;
  border-radius: 8rpx;
  color: #8e241b;
  background: #fff1ef;
  font-size: 26rpx;
}

.save-btn {
  margin-top: 28rpx;
}
