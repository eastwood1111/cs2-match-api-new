<view class="page index-page">
  <view class="app-header">
    <button class="header-icon" bindtap="goBind">☰</button>
    <text class="app-title">CS</text>
    <button class="header-icon" loading="{{syncing}}" disabled="{{syncing}}" bindtap="syncMatches">↻</button>
  </view>

  <view wx:if="{{error}}" class="notice">{{error}}</view>
  <view wx:if="{{hasMockData}}" class="notice warning-notice">当前包含测试占位数据。</view>

  <view wx:if="{{loading}}" class="loading-panel">加载中</view>

  <block wx:else>
    <view class="section-head">
      <view>
        <text class="section-title">我的比赛</text>
        <text class="down-mark">⌄</text>
      </view>
      <button class="sync-btn" loading="{{syncing}}" disabled="{{syncing}}" bindtap="syncMatches">{{syncing ? '同步中' : '同步'}}</button>
    </view>

    <view wx:if="{{steamAccount}}" class="account-strip" bindtap="goBind">
      <view>
        <text class="account-name">{{steamAccount.steamName || '已绑定账号'}}</text>
        <text class="account-id">{{steamAccount.steamId64}}</text>
      </view>
      <text class="account-action">编辑</text>
    </view>

    <view wx:else class="bind-strip">
      <text>未绑定 Steam</text>
      <button class="bind-btn" bindtap="goBind">绑定</button>
    </view>

    <view class="summary-strip">
      <view class="summary-item">
        <text class="summary-value">{{dashboard.total}}</text>
        <text class="summary-label">全部</text>
      </view>
      <view class="summary-item">
        <text class="summary-value green-value">{{dashboard.parsedTotal}}</text>
        <text class="summary-label">已解析</text>
      </view>
      <view class="summary-item">
        <text class="summary-value amber-value">{{dashboard.pendingTotal}}</text>
        <text class="summary-label">待解析</text>
      </view>
      <view class="summary-item">
        <text class="summary-value date-value">{{dashboard.latestText}}</text>
        <text class="summary-label">最近</text>
      </view>
    </view>

    <view wx:if="{{!hasMatches}}" class="empty-list">
      <text>暂无比赛</text>
    </view>

    <view wx:else class="match-table">
      <view class="table-head">
        <text>赛果</text>
        <text>比分</text>
        <text>地图</text>
        <text>Rating/KDA</text>
        <text>Rank</text>
      </view>

      <view wx:for="{{matches}}" wx:key="id" class="table-row" bindtap="goMatch" data-id="{{item.id}}">
        <view class="result-cell">
          <text wx:if="{{item.isMvp}}" class="mvp-mark">MVP</text>
          <text class="result-badge {{item.resultBadgeClass}}">{{item.resultLabel}}</text>
          <text class="row-date">{{item.resultDate}}</text>
        </view>

        <view class="score-cell {{item.scoreClass}}">
          <text>{{item.scoreLeft}}</text>
          <text class="score-sep">:</text>
          <text>{{item.scoreRight}}</text>
        </view>

        <view class="map-cell">
          <text class="map-name">{{item.mapText}}</text>
          <text class="mode-name">{{item.modeText}}</text>
        </view>

        <view class="rating-cell">
          <text class="rating {{item.ratingClass}}">{{item.ratingText}}</text>
          <text class="kda">{{item.kdaText}}</text>
        </view>

        <view class="rank-cell">
          <text class="rank-chip">{{item.rankText}}</text>
          <text class="rank-delta">{{item.rankDelta}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-tabs">
    <view class="tab-item">
      <text class="tab-icon">⌖</text>
      <text>发现</text>
    </view>
    <view class="tab-item">
      <text class="tab-icon">♜</text>
      <text>赛事</text>
    </view>
    <view class="tab-item">
      <text class="tab-icon">□</text>
      <text>社区</text>
    </view>
    <view class="tab-item active-tab">
      <text class="tab-icon">◇</text>
      <text>数据</text>
    </view>
    <view class="tab-item">
      <text class="tab-icon">◉</text>
      <text>我的</text>
    </view>
  </view>
</view>
