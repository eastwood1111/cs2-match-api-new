.index-page {
  padding-bottom: 48rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.eyebrow {
  color: #6f7681;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.title {
  margin-top: 6rpx;
  color: #111315;
  font-size: 52rpx;
  line-height: 1.05;
  font-weight: 900;
}

.notice {
  margin-bottom: 22rpx;
  padding: 20rpx 22rpx;
  border-left: 8rpx solid #d84a3a;
  border-radius: 8rpx;
  color: #8e241b;
  background: #fff1ef;
  font-size: 26rpx;
}

.warning-notice {
  border-left-color: #a86f12;
  color: #7a4d0b;
  background: #fff6e7;
}

.loading-panel,
.empty-panel,
.account-panel,
.empty-list {
  box-sizing: border-box;
  border: 1rpx solid #e0e3e8;
  border-radius: 8rpx;
  background: #ffffff;
}

.loading-panel,
.empty-list {
  padding: 48rpx 28rpx;
  color: #747b86;
  text-align: center;
}

.empty-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  color: #17191c;
  font-size: 34rpx;
  font-weight: 800;
}

.empty-panel .primary-btn {
  width: 220rpx;
}

.account-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.label {
  color: #747b86;
  font-size: 22rpx;
  font-weight: 800;
}

.steam-name {
  margin-top: 8rpx;
  color: #17191c;
  font-size: 34rpx;
  font-weight: 900;
}

.steam-id {
  display: block;
  margin-top: 6rpx;
  color: #747b86;
  font-size: 24rpx;
}

.small-btn {
  width: 132rpx;
  height: 72rpx;
  font-size: 26rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 30rpx;
}

.stat-tile {
  box-sizing: border-box;
  min-height: 150rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #202328;
}

.accent-green {
  background: #16895d;
}

.accent-amber {
  background: #a86f12;
}

.accent-red {
  background: #b74335;
}

.stat-value {
  display: block;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 900;
}

.stat-label {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.78;
}

.section-title {
  margin: 8rpx 0 18rpx;
  color: #17191c;
  font-size: 30rpx;
  font-weight: 900;
}

.match-card {
  box-sizing: border-box;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e0e3e8;
  border-radius: 8rpx;
  background: #ffffff;
}

.match-main,
.match-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.match-footer {
  margin-top: 22rpx;
  color: #747b86;
  font-size: 24rpx;
}

.map-name {
  color: #17191c;
  font-size: 32rpx;
  font-weight: 900;
}

.match-meta {
  margin-top: 8rpx;
  color: #747b86;
  font-size: 24rpx;
}

.source-label {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  color: #7a4d0b;
  background: #fff6e7;
  font-size: 22rpx;
  font-weight: 800;
}

.score {
  color: #17191c;
  font-size: 34rpx;
  font-weight: 900;
}

.result {
  min-width: 74rpx;
  font-weight: 900;
}

.result-win {
  color: #16895d;
}

.result-loss {
  color: #b74335;
}

.result-draw {
  color: #a86f12;
}
