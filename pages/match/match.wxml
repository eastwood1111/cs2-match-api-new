<view class="page match-page">
  <view wx:if="{{loading}}" class="loading-panel">加载中</view>

  <view wx:elif="{{error}}" class="notice">{{error}}</view>

  <block wx:elif="{{match}}">
    <view class="hero {{match.resultHeroClass}}">
      <view class="hero-nav">
        <button class="hero-icon" bindtap="goBack">‹</button>
        <view class="brand-pill">
          <text class="brand-mark">CS</text>
          <text>Steam 官方匹配</text>
        </view>
        <button class="hero-icon" bindtap="copyShareCode">↗</button>
      </view>

      <view class="hero-scoreboard">
        <text class="hero-result">{{match.resultText}}</text>
        <view class="big-score">
          <text>{{match.scoreLeft}}</text>
          <text class="score-sep">:</text>
          <text>{{match.scoreRight}}</text>
        </view>
      </view>

      <view class="hero-meta-grid">
        <view wx:for="{{match.heroMeta}}" wx:key="label" class="hero-meta-item">
          <text class="hero-meta-label">{{item.label}}</text>
          <text class="hero-meta-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <view class="basic-grid">
      <view wx:for="{{match.basicCards}}" wx:key="label" class="basic-card">
        <text class="basic-value">{{item.value}}</text>
        <text class="basic-label">{{item.label}}</text>
      </view>
    </view>

    <view wx:for="{{match.teamSections}}" wx:for-item="section" wx:key="id" class="team-section {{section.id === 'opponent' ? 'opponent-section' : ''}}">
      <view class="team-title">
        <text>{{section.name}}</text>
        <text class="team-result">{{section.resultText}}</text>
      </view>

      <view class="player-table">
        <view class="player-head">
          <text>玩家</text>
          <text>KDA</text>
          <text>ADR</text>
        </view>

        <view wx:for="{{section.rows}}" wx:for-item="item" wx:key="key" class="player-wrap">
          <view class="player-row {{item.isCurrentUser ? 'current-player' : ''}}" bindtap="togglePlayer" data-key="{{item.key}}" data-expandable="{{item.isCurrentUser}}">
            <view class="player-name-cell">
              <view class="avatar">{{item.avatarText}}</view>
              <view class="name-block">
                <text class="player-name">{{item.name}}</text>
                <text wx:if="{{item.isCurrentUser}}" class="self-tag">我的数据</text>
                <text wx:elif="{{item.isPlaceholder}}" class="self-tag muted-tag">待解析</text>
              </view>
            </view>
            <text class="metric-text">{{item.kda}}</text>
            <text class="metric-text">{{item.adr}}</text>
          </view>

          <view wx:if="{{item.isExpanded}}" class="expand-panel">
            <view wx:for="{{item.detailRows}}" wx:for-item="detail" wx:key="label" class="detail-row">
              <text class="detail-label">{{detail.label}}</text>
              <text class="detail-value">{{detail.value}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{match.isShareCodeOnly}}" class="share-panel">
      <text class="share-label">分享码</text>
      <text class="share-value">{{match.shareCodeText}}</text>
      <button class="copy-btn" bindtap="copyShareCode">复制</button>
    </view>
  </block>
</view>
