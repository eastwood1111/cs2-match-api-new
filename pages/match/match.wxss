.match-page {
  min-height: 100vh;
  padding: 0 0 44rpx;
  background: #f4f5f7;
}

.loading-panel {
  margin: 28rpx;
  padding: 56rpx 28rpx;
  border-radius: 8rpx;
  color: #747b86;
  background: #ffffff;
  text-align: center;
}

.notice {
  margin: 28rpx;
  padding: 20rpx 22rpx;
  border-left: 8rpx solid #d84a3a;
  border-radius: 8rpx;
  color: #8e241b;
  background: #fff1ef;
  font-size: 26rpx;
}

.hero {
  min-height: 520rpx;
  box-sizing: border-box;
  padding: 34rpx 30rpx 34rpx;
  color: #ffffff;
  background:
    linear-gradient(rgba(19, 27, 37, 0.78), rgba(13, 18, 25, 0.95)),
    linear-gradient(135deg, #243342, #11171f 55%, #2b2319);
}

.hero-nav {
  display: grid;
  grid-template-columns: 84rpx 1fr 84rpx;
  align-items: center;
}

.hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 600;
}

.brand-pill {
  justify-self: center;
  display: flex;
  align-items: center;
  gap: 12rpx;
  max-width: 390rpx;
  height: 64rpx;
  box-sizing: border-box;
  padding: 0 24rpx 0 14rpx;
  border-radius: 32rpx;
  color: #32363d;
  background: rgba(255, 255, 255, 0.92);
  font-size: 27rpx;
  font-weight: 900;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #c1342f;
  font-size: 20rpx;
}

.hero-scoreboard {
  margin-top: 44rpx;
  text-align: center;
}

.hero-result {
  display: block;
  color: #63d84c;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 900;
}

.hero-loss .hero-result {
  color: #ff6b5f;
}

.hero-pending .hero-result {
  color: #f5b82e;
}

.big-score {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 16rpx;
  margin-top: -8rpx;
  color: #ffffff;
  font-size: 92rpx;
  line-height: 1;
  font-weight: 900;
}

.score-slash {
  color: #ffffff;
  opacity: 0.85;
}

.round-line {
  display: block;
  margin-top: 22rpx;
  color: #1593ff;
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.hero-meta-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 48rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.18);
}

.hero-meta-item {
  min-width: 0;
  text-align: center;
}

.hero-meta-label {
  display: block;
  color: rgba(255, 255, 255, 0.48);
  font-size: 24rpx;
  font-weight: 800;
}

.hero-meta-value {
  display: block;
  margin-top: 12rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.94);
  font-size: 26rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tabs-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr)) 186rpx;
  align-items: center;
  min-height: 104rpx;
  padding: 0 20rpx;
  background: #ffffff;
}

.tab {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 104rpx;
  color: #4a4e55;
  font-size: 29rpx;
  font-weight: 800;
}

.active-tab::after {
  position: absolute;
  right: 40rpx;
  bottom: 0;
  left: 40rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #1593ff;
  content: "";
}

.demo-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  border: 2rpx solid #1593ff;
  border-radius: 6rpx;
  color: #1593ff;
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
}

.team-ribbon {
  display: inline-flex;
  align-items: center;
  gap: 22rpx;
  min-width: 420rpx;
  height: 72rpx;
  margin-top: 22rpx;
  padding: 0 30rpx;
  color: #ffffff;
  background: #f5b82e;
  font-size: 32rpx;
  font-weight: 900;
}

.team-result {
  font-size: 34rpx;
}

.player-summary {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 480rpx;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 28rpx;
  background: #ffffff;
}

.player-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.avatar,
.small-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  border-radius: 50%;
  color: #ffffff;
  background: #202328;
  font-weight: 900;
}

.avatar {
  width: 82rpx;
  height: 82rpx;
  font-size: 28rpx;
}

.player-name-wrap,
.row-name-wrap {
  min-width: 0;
}

.mvp-badge {
  display: inline-block;
  margin-right: 8rpx;
  color: #f5b82e;
  font-size: 22rpx;
  font-style: italic;
  font-weight: 900;
}

.player-name {
  color: #333840;
  font-size: 28rpx;
  font-weight: 900;
}

.rank-bar {
  display: block;
  width: 126rpx;
  height: 38rpx;
  margin-top: 8rpx;
  border-left: 8rpx solid #e64ae8;
  color: #f3c8ff;
  background: #673082;
  font-size: 20rpx;
  line-height: 38rpx;
  text-align: center;
  font-style: italic;
  font-weight: 900;
}

.player-numbers {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  text-align: center;
}

.number-label {
  display: block;
  color: #767d87;
  font-size: 24rpx;
}

.number-value {
  display: block;
  margin-top: 12rpx;
  color: #333840;
  font-size: 28rpx;
  font-weight: 900;
}

.rating-value {
  color: #69bfae;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  padding: 22rpx;
  background: #ffffff;
}

.stat-card {
  min-height: 106rpx;
  box-sizing: border-box;
  padding: 18rpx 8rpx;
  background: #eef2f6;
  text-align: center;
}

.stat-value {
  display: block;
  overflow: hidden;
  color: #30343a;
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  display: block;
  margin-top: 12rpx;
  color: #737983;
  font-size: 23rpx;
}

.players-table {
  margin-top: 22rpx;
  background: #ffffff;
}

.player-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 90rpx 80rpx 80rpx 88rpx;
  gap: 12rpx;
  align-items: center;
  min-height: 118rpx;
  padding: 18rpx 28rpx;
  border-bottom: 1rpx solid #eef0f3;
  color: #333840;
  font-size: 25rpx;
  font-weight: 800;
}

.player-row:last-child {
  border-bottom: 0;
}

.current-player {
  background: #fbfcfd;
}

.small-avatar {
  width: 60rpx;
  height: 60rpx;
  font-size: 22rpx;
}

.row-name {
  display: block;
  overflow: hidden;
  color: #333840;
  font-size: 27rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-rank {
  width: 108rpx;
  height: 32rpx;
  font-size: 18rpx;
  line-height: 32rpx;
}

.round-board {
  margin-top: 22rpx;
  overflow-x: auto;
  background: #ffffff;
}

.round-header,
.round-row {
  display: grid;
  grid-template-columns: 70rpx repeat(18, 44rpx);
  align-items: center;
  min-width: 862rpx;
  min-height: 58rpx;
  border-bottom: 1rpx solid #eef0f3;
}

.round-title,
.round-team {
  color: #737983;
  font-size: 24rpx;
  text-align: center;
}

.round-team {
  color: #1593ff;
  font-weight: 900;
}

.round-cell {
  min-width: 0;
  color: #767d87;
  font-size: 22rpx;
  text-align: center;
}

.round-win {
  color: #1593ff;
}

.round-loss {
  color: #f5b82e;
}

.round-special {
  color: #5fbd57;
}

.share-panel {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 112rpx;
  align-items: center;
  gap: 16rpx;
  margin: 22rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.share-label {
  color: #737983;
  font-size: 24rpx;
}

.share-value {
  overflow: hidden;
  color: #333840;
  font-size: 22rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #1593ff;
  font-size: 24rpx;
  font-weight: 800;
}
