.match-page {
  min-height: 100vh;
  padding: 0 0 44rpx;
  background: #f4f5f7;
}

.loading-panel {
  margin: 28rpx;
  padding: 56rpx 28rpx;
  border-radius: 8rpx;
  color: #747b86;
  background: #ffffff;
  text-align: center;
}

.notice {
  margin: 28rpx;
  padding: 20rpx 22rpx;
  border-left: 8rpx solid #d84a3a;
  border-radius: 8rpx;
  color: #8e241b;
  background: #fff1ef;
  font-size: 26rpx;
}

.hero {
  min-height: 450rpx;
  box-sizing: border-box;
  padding: 34rpx 30rpx;
  color: #ffffff;
  background:
    linear-gradient(rgba(19, 27, 37, 0.78), rgba(13, 18, 25, 0.95)),
    linear-gradient(135deg, #243342, #11171f 55%, #2b2319);
}

.hero-nav {
  display: grid;
  grid-template-columns: 84rpx 1fr 84rpx;
  align-items: center;
}

.hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 600;
}

.brand-pill {
  justify-self: center;
  display: flex;
  align-items: center;
  gap: 12rpx;
  max-width: 390rpx;
  height: 64rpx;
  box-sizing: border-box;
  padding: 0 24rpx 0 14rpx;
  border-radius: 32rpx;
  color: #32363d;
  background: rgba(255, 255, 255, 0.92);
  font-size: 27rpx;
  font-weight: 900;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #c1342f;
  font-size: 20rpx;
}

.hero-scoreboard {
  margin-top: 46rpx;
  text-align: center;
}

.hero-result {
  display: block;
  color: #63d84c;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 900;
}

.hero-loss .hero-result {
  color: #ff6b5f;
}

.hero-pending .hero-result {
  color: #f5b82e;
}

.big-score {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 82rpx;
  line-height: 1;
  font-weight: 900;
}

.score-sep {
  color: rgba(255, 255, 255, 0.82);
}

.hero-meta-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 48rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.18);
}

.hero-meta-item {
  min-width: 0;
  text-align: center;
}

.hero-meta-label {
  display: block;
  color: rgba(255, 255, 255, 0.48);
  font-size: 24rpx;
  font-weight: 800;
}

.hero-meta-value {
  display: block;
  margin-top: 12rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.94);
  font-size: 26rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.basic-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  padding: 22rpx;
  background: #ffffff;
}

.basic-card {
  min-height: 106rpx;
  box-sizing: border-box;
  padding: 18rpx 8rpx;
  background: #eef2f6;
  text-align: center;
}

.basic-value {
  display: block;
  overflow: hidden;
  color: #30343a;
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.basic-label {
  display: block;
  margin-top: 12rpx;
  color: #737983;
  font-size: 23rpx;
}

.team-section {
  margin-top: 22rpx;
  background: #ffffff;
}

.team-title {
  display: flex;
  align-items: center;
  gap: 22rpx;
  height: 72rpx;
  padding: 0 30rpx;
  color: #ffffff;
  background: #f5b82e;
  font-size: 32rpx;
  font-weight: 900;
}

.opponent-section .team-title {
  background: #3d4652;
}

.team-result {
  font-size: 32rpx;
}

.player-table {
  overflow: hidden;
}

.player-head,
.player-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 128rpx 110rpx;
  align-items: center;
  gap: 16rpx;
}

.player-head {
  min-height: 66rpx;
  padding: 0 28rpx;
  color: #767d87;
  background: #f0f5fa;
  font-size: 24rpx;
}

.player-wrap {
  border-bottom: 1rpx solid #eef0f3;
}

.player-wrap:last-child {
  border-bottom: 0;
}

.player-row {
  min-height: 106rpx;
  padding: 18rpx 28rpx;
  color: #333840;
  font-size: 25rpx;
  font-weight: 800;
}

.current-player {
  background: #fbfcfd;
}

.player-name-cell {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #202328;
  font-size: 22rpx;
  font-weight: 900;
}

.name-block {
  min-width: 0;
}

.player-name {
  display: block;
  overflow: hidden;
  color: #333840;
  font-size: 27rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.self-tag {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  color: #0f5d40;
  background: #ecf8f3;
  font-size: 20rpx;
  font-weight: 900;
}

.muted-tag {
  color: #7a8290;
  background: #eef2f6;
}

.metric-text {
  color: #333840;
  font-size: 27rpx;
  font-weight: 900;
  text-align: center;
}

.expand-panel {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  padding: 0 28rpx 20rpx 104rpx;
  background: #fbfcfd;
}

.detail-row {
  min-height: 82rpx;
  box-sizing: border-box;
  padding: 14rpx 10rpx;
  border-radius: 8rpx;
  background: #eef2f6;
  text-align: center;
}

.detail-label {
  display: block;
  color: #737983;
  font-size: 22rpx;
}

.detail-value {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #30343a;
  font-size: 25rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-panel {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 112rpx;
  align-items: center;
  gap: 16rpx;
  margin: 22rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.share-label {
  color: #737983;
  font-size: 24rpx;
}

.share-value {
  overflow: hidden;
  color: #333840;
  font-size: 22rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #1593ff;
  font-size: 24rpx;
  font-weight: 800;
}
