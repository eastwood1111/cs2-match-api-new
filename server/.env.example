PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# Local default uses a JSON file. Set DB_DIALECT=mysql in WeChat Cloud Run.
DB_DIALECT=json
DATA_FILE=./data/dev-db.json
ENABLE_MOCK_SYNC=true

# MySQL for WeChat Cloud Run / cloud database.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=cs2_match

# Compatible with common WeChat Cloud Run templates.
# MYSQL_ADDRESS=host:3306
# MYSQL_USERNAME=

# Optional: only needed when not relying on Cloud Run injected openid.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
